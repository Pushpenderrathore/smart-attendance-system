# Smart Attendance System v2 — Environment Variables
# Copy to .env: cp .env.example .env
# Generate SECRET_KEY: python3 -c "import secrets; print(secrets.token_hex(32))"

# ── Security ───────────────────────────────────────────────
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-64-CHARACTER-STRING

# ── Flask ──────────────────────────────────────────────────
FLASK_ENV=development

# ── OTP ────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=60

# ── Geofencing (your actual classroom GPS) ─────────────────
CLASSROOM_LAT=28.7041
CLASSROOM_LON=77.1025
GEOFENCE_RADIUS=100

# ── Database ───────────────────────────────────────────────
# SQLite (default, great for development):
# DATABASE_URL=sqlite:///attendance.db
#
# MySQL (production):
# DATABASE_URL=mysql://user:password@localhost/attendance_db
#
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost/attendance_db

DATABASE_URL=sqlite:///attendance.db

# ── Frontend ───────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000
