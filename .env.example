# ── Smart Attendance System — Environment Variables ──────────
# Copy this file to .env and fill in your values.
# Never commit .env to git!

# Flask
SECRET_KEY=change-me-to-something-secure
FLASK_ENV=development

# OTP
OTP_EXPIRY_SECONDS=60

# Geofencing (set to your actual classroom coordinates)
CLASSROOM_LAT=28.7041
CLASSROOM_LON=77.1025
GEOFENCE_RADIUS=100

# Database (default: SQLite)
# For MySQL: mysql://user:password@localhost/attendance_db
# For PostgreSQL: postgresql://user:password@localhost/attendance_db
DATABASE_URL=sqlite:///attendance.db

# Frontend API URL (used in React build)
REACT_APP_API_URL=http://localhost:5000
